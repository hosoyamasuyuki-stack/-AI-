# ============================================================
# AI Investment System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Google Sheets API (service account JSON)
# Get from: Google Cloud Console > Service Accounts > Keys
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Google Spreadsheet ID
# From the URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit
SPREADSHEET_ID=1GtlVhGcPjMU0pJWsijwnmTe1rFJXAGvkaJFjav9gGcE

# J-Quants API (Japanese stock data)
# Get from: https://jpx-jquants.com/
JQUANTS_API_KEY=your_jquants_api_key_here

# FRED API (Federal Reserve Economic Data)
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# EDINET API (Japanese corporate disclosure)
# Get from: https://disclosure.edinet-fsa.go.jp/
EDINET_API_KEY=your_edinet_api_key_here

# GitHub Personal Access Token (Classic, repo+workflow scope)
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Anthropic Claude API (for Deep Insight Analysis)
# Get from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here
