# ============================================================
# AI Investment System - Environment Variables
# Copy this file to .env and fill in your values
#
# 【重要】APIキー管理ルール
# 1. ローカル: .env に設定（gitignore済み）
# 2. GitHub Actions: Settings > Secrets に設定
# 3. GASプロキシ: スクリプトプロパティに設定
# 4. 変更時は check_api_keys.py で健全性チェック
# ============================================================

# ── ローカル + GitHub Secrets 両方に必要 ──────────────────────

# Google Sheets API (service account JSON)
# 取得先: Google Cloud Console > Service Accounts > Keys
# 設定先: .env + GitHub Secrets「GOOGLE_CREDENTIALS」
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Google Spreadsheet ID
# 取得先: Google Sheets URL の /d/{THIS_PART}/edit
# 設定先: .env + GitHub Secrets「SPREADSHEET_ID」
SPREADSHEET_ID=1GtlVhGcPjMU0pJWsijwnmTe1rFJXAGvkaJFjav9gGcE

# J-Quants API (日本株データ: 株価・財務・PEG・FCF利回り)
# 取得先: https://jpx-jquants.com/ > マイページ > APIキー
# 設定先: .env + GitHub Secrets「JQUANTS_API_KEY」
# 使用: weekly_update / daily_price_update / full_scan / manage_stock / verify
# 【注意】未設定だと変数3が全銘柄50点（デフォルト）になる
JQUANTS_API_KEY=your_jquants_api_key_here

# FRED API (米国マクロ経済指標: VIX/HYG/金利/M2等 25指標)
# 取得先: https://fred.stlouisfed.org/docs/api/api_key.html
# 設定先: .env + GitHub Secrets「FRED_API_KEY」
# 使用: daily_update / generate_dashboard
FRED_API_KEY=your_fred_api_key_here

# GitHub Personal Access Token (Classic, repo+workflow scope)
# 取得先: https://github.com/settings/tokens
# 設定先: .env（ローカル用）/ GitHub Secrets は自動提供（GITHUB_TOKEN）
# 使用: full_update (push) / GASプロキシ (workflow_dispatch)
# 【注意】90日で期限切れ。更新時は.envとGASプロパティ両方を更新
GITHUB_TOKEN=your_github_token_here

# ── ローカルのみ（GitHub Secrets不要）────────────────────────

# EDINET API (日本企業の有価証券報告書)
# 取得先: https://disclosure.edinet-fsa.go.jp/
# 設定先: .env + GASスクリプトプロパティ「EDINET_API_KEY」
# 使用: 賢者の審判（GAS経由）
EDINET_API_KEY=your_edinet_api_key_here

# ── GASスクリプトプロパティのみ（.env/Secrets不要）───────────
# 以下はGASプロジェクト設定 > スクリプトプロパティに設定
#
# OPENAI_API_KEY (kenja-rich-api): 賢者の審判のAI分析
#   取得先: https://platform.openai.com/api-keys
#
# EDINET_API_KEY: EDINET開示書類検索
#   取得先: https://disclosure.edinet-fsa.go.jp/
#
# GITHUB_TOKEN: workflow_dispatch発火用
#   取得先: 上記と同じClassicトークン

# ============================================================
# 健全性チェック: python check_api_keys.py
# ============================================================
